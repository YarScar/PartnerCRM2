generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PartnerStatus {
  id         Int     @id @default(autoincrement())
  label      String  @unique
  color      String
  sort_order Int     @default(0)

  @@map("partner_statuses")
}

model Partner {
  id                      Int          @id @default(autoincrement())
  org_name                String
  contact_name            String?
  contact_email           String?
  contact_phone           String?
  contact_role            String?
  org_website             String?
  org_address             String?
  org_city                String?
  org_state               String?
  status                  String       @default("New")
  program_structure       String?
  who_they_work_with      String?
  youth_ages              String?
  how_kids_connect        String?
  intake_message          String?
  recruitment_needed      Boolean?
  recruitment_notes       String?
  program_times           String?
  schedule_flexibility    String?
  desired_program_type    String?
  specific_project_request String?
  wants_recommendations   Boolean      @default(false)
  desired_timeline        String?
  firm_dates              String?
  works_with_3d_tech      String?
  three_d_tech_specifics  String?
  hardware_inventory      Json?
  hardware_notes          String?
  available_computers     String?
  internet_availability   String?
  available_space         String?
  on_site_assistance      Boolean?
  on_site_assistance_notes String?
  accessibility_limitations String?
  general_tech_context    String?
  source                  String?      @default("manual")
  created_at              DateTime     @default(now()) @db.Timestamptz(6)
  updated_at              DateTime     @updatedAt @db.Timestamptz(6)

  notes                   PartnerNote[]

  @@index([status], map: "idx_partners_status")
  @@index([created_at(sort: Desc)], map: "idx_partners_created_at")
  @@map("partners")
}

model PartnerNote {
  id         Int      @id @default(autoincrement())
  partner_id Int
  body       String
  author     String?
  created_at DateTime @default(now()) @db.Timestamptz(6)

  partner    Partner  @relation(fields: [partner_id], references: [id], onDelete: Cascade)

  @@index([partner_id], map: "idx_partner_notes_partner_id")
  @@map("partner_notes")
}

model User {
  id            Int      @id @default(autoincrement())
  username      String   @unique
  password_hash String
  display_name  String
  role          String   @default("staff")
  created_at    DateTime @default(now()) @db.Timestamptz(6)
  updated_at    DateTime @updatedAt @db.Timestamptz(6)

  @@index([username], map: "idx_users_username")
  @@map("users")
}

model FormConfig {
  id            Int      @id @default(autoincrement())
  section_key   String
  section_label String
  field_key     String
  field_label   String
  field_type    String
  options       Json?
  visible       Boolean? @default(true)
  required      Boolean? @default(false)
  sort_order    Int?     @default(0)

  @@unique([section_key, field_key])
  @@map("form_config")
}
