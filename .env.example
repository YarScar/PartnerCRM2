# Get this from your Neon dashboard: https://console.neon.tech
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=

# When DATABASE_URL is empty, the app falls back to mock data automatically.

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Session / security
AUTH_SECRET=

# Account-based login for the internal app (dev defaults)
ADMIN_ACCOUNT_USERNAME=admin
ADMIN_ACCOUNT_PASSWORD=admin123
STAFF_ACCOUNT_USERNAME=staff
STAFF_ACCOUNT_PASSWORD=staff123

# Admin notification email (used as fallback/recipient in some notifications)
ADMIN_NOTIFICATION_EMAIL=ykeme0086@launchpadphilly.org
NOTIFICATION_FROM_EMAIL=CreateAccess <notifications@createaccess.local>

# --- Email / SMTP (Gmail) ---
# Use Gmail SMTP for sending emails. If your account has 2FA, create an App Password
# and use it as the EMAIL_PASS. For STARTTLS use port 587 with EMAIL_SECURE=false.
# For implicit SSL use port 465 and set EMAIL_SECURE=true.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
# Set to "true" when using port 465 (SSL). Keep "false" for port 587 (STARTTLS).
EMAIL_SECURE=false
EMAIL_USER=yourgmail@gmail.com
EMAIL_PASS=your_gmail_app_password_or_app_password_if_2fa_enabled
EMAIL_FROM_NAME="PartnerCRM"
EMAIL_FROM_ADDRESS=yourgmail@gmail.com

# --- OpenAI / AI digest ---
OPENAI_API_KEY=

# Legacy/resend placeholder (if still used elsewhere)
RESEND_API_KEY=
 